# --- Real MedGemma (HAI-DEF) on Vertex AI ---
# Set these to use the deployed MedGemma model from Model Garden.
# MEDGEMMA_USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MEDGEMMA_ENDPOINT_ID=your-endpoint-id

# --- HEAR (HAI-DEF) on Vertex AI — optional second model ---
