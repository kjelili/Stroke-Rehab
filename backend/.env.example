# --- MedSigLIP (HAI-DEF) on Vertex AI — optional image/text encoder ---
# MEDSIGLIP_VERTEX_ENDPOINT_ID=your-medsiglip-endpoint-id

# Optional: model name when using Gemini (default: gemini-2.0-flash)
# MEDGEMMA_MODEL=gemini-2.0-flash

# Optional: port (default: 4000)
# PORT=4000
